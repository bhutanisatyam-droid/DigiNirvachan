PORT=3001
NODE_ENV=development

# Hyperledger Fabric connection
CHANNEL_NAME=election-channel
CHAINCODE_NAME=evoting
MSP_ID=ECIOrgMSP

# Path to the ECI org crypto material (relative to api-gateway/src/)
CRYPTO_PATH=../fabric-network/organizations/peerOrganizations/eci.example.com

# Peer gRPC endpoint (the peer container is exposed on port 7051)
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.eci.example.com
