        "express": "^4.18.0",
        "fabric-ca-client": "^2.2.0",
        "helmet": "^7.0.0",
        "morgan": "^1.10.0",
        "uuid": "^9.0.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.14",
        "@types/express": "^4.17.21",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.0.0",
        "@types/uuid": "^9.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.0.0"
