# Environment configuration for the E-Voting API Gateway
# Copy this file to .env and fill in the actual values.

# ── Fabric Network ──────────────────────────────────────────
CHANNEL_NAME=election-channel
CHAINCODE_NAME=evoting

# ── Peer & TLS ──────────────────────────────────────────────
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.eci.example.com

# ── Identity (ECI Admin) ─────────────────────────────────────
MSP_ID=ECIOrgMSP
CRYPTO_PATH=../fabric-network/organizations/peerOrganizations/eci.example.com

# ── Fabric CA ───────────────────────────────────────────────
CA_URL=https://localhost:7054
CA_NAME=ca-eci
CA_ADMIN_NAME=admin
CA_ADMIN_PASSWORD=adminpw

# ── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Security ────────────────────────────────────────────────
API_SECRET=your-secret-key-here
